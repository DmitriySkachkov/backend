        {
          "name": "GET All Books",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response is array\", function () {\r",
                  "    const response = pm.response.json();\r",
                  "    pm.expect(response).to.be.an('array');\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Books have required fields\", function () {\r",
                  "    const response = pm.response.json();\r",
                  "    if (response.length > 0) {\r",
                  "        response.forEach(book => {\r",
                  "            pm.expect(book).to.have.property('id');\r",
                  "            pm.expect(book).to.have.property('title');\r",
                  "            pm.expect(book).to.have.property('author');\r",
                  "        });\r",
                  "    }\r",
                  "});\r",
                  "\r",
                  "// Сохраняем первый ID для дальнейших тестов\r",
                  "const response = pm.response.json();\r",
                  "if (response.length > 0) {\r",
                  "    pm.environment.set(\"book_id\", response[0].id);\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
